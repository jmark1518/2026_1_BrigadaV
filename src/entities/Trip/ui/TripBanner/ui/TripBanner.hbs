<article class="{{s 'banner'}} {{className}}">
  <img src="{{trip.preview}}" class="{{s 'banner__bg'}}">

  <div class="{{s 'banner__content'}}">
    <h2 class="{{s 'banner__title'}}">{{trip.title}}</h2>

    <div class="{{s 'banner__meta'}}">
      <div class="{{s 'banner__date-wrapper'}}">
        <time class="{{s 'banner__date-start'}}" datetime="{{isoStart}}">{{start}}</time> &ndash;
        <time class="{{s 'banner__date-end'}}" datetime="{{isoEnd}}">{{end}}</time>
      </div>
      <span class="{{s 'banner__location'}}">{{trip.location}}</span>
    </div>

  </div>

  <button class="{{s 'banner__delete'}}" data-delete-button>
    <img src="/icons/bin.svg" class="{{s 'banner__delete-img'}}">
  </button>
</article>
